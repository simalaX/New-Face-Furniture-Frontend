# Copy this file to .env and fill in your credentials

# PostgreSQL connection URL
# Example: postgresql://user:password@localhost:5432/mydb
DATABASE_URL=

# Cloudinary credentials (do NOT commit your real secrets)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin credentials and JWT secret for server-side auth
# Choose a strong password and keep this file private
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SECRET_KEY=replace-this-with-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend origin (used for CORS)
FRONTEND_URL=http://localhost:3000
